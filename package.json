{
  "name": "@shichengsh001/xrpl-up",
  "version": "0.1.7",
  "description": "XRPL sandbox for local development",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ripple/xrpl-up.git"
  },
  "keywords": [
    "xrpl",
    "xrp",
    "blockchain",
    "development",
    "sandbox"
  ],
  "bin": {
    "xrpl-up": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "cp src/faucet-server/package.json dist/faucet-server/package.json && cp src/faucet-server/Dockerfile dist/faucet-server/Dockerfile && chmod +x dist/cli.js && mkdir -p dist/core/genesis && cp src/core/genesis/*.tar.gz dist/core/genesis/",
    "dev": "tsx src/cli.ts",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run tests/e2e",
    "test:e2e:local": "vitest run --config vitest.config.local.ts tests/e2e",
    "test:e2e:local-network": "vitest run --config vitest.config.local-network.ts tests/e2e",
    "test:e2e:snapshot": "vitest run --config vitest.config.snapshot.ts",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist/",
    "src/faucet-server/Dockerfile",
    "src/faucet-server/package.json",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@xrplf/isomorphic": "^1.0.1",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "xrpl": "^4.6.0"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  }
}
