<Worksheet ss:Name="Phase 1 Plan">
<Table>
<Row>
<Cell><Data ss:Type="String">No.</Data></Cell>
<Cell><Data ss:Type="String">Capability</Data></Cell>
<Cell><Data ss:Type="String">Why it belongs in Phase 1</Data></Cell>
<Cell><Data ss:Type="String">Current commands / scope</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">1</Data></Cell>
<Cell><Data ss:Type="String">Local sandbox lifecycle</Data></Cell>
<Cell><Data ss:Type="String">Supports local development and CI usage by making sandbox start, stop, reset, inspection, and troubleshooting repeatable.</Data></Cell>
<Cell><Data ss:Type="String">node / stop / reset / logs / status / accounts</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">2</Data></Cell>
<Cell><Data ss:Type="String">Local amendment controls</Data></Cell>
<Cell><Data ss:Type="String">Supports local-only amendment testing and alignment against other networks.</Data></Cell>
<Cell><Data ss:Type="String">amendment list / info / enable / disable / sync</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">3</Data></Cell>
<Cell><Data ss:Type="String">Custom Docker image and tag</Data></Cell>
<Cell><Data ss:Type="String">Supports local development and CI usage against pinned or custom xrpld container builds.</Data></Cell>
<Cell><Data ss:Type="String">custom docker image repository and tag selection for sandbox runs</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">4</Data></Cell>
<Cell><Data ss:Type="String">Faucet funding</Data></Cell>
<Cell><Data ss:Type="String">Required for quick account setup across local, testnet, and devnet workflows.</Data></Cell>
<Cell><Data ss:Type="String">faucet</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">5</Data></Cell>
<Cell><Data ss:Type="String">Snapshots</Data></Cell>
<Cell><Data ss:Type="String">Enables repeatable local state and fast rollback during development and testing.</Data></Cell>
<Cell><Data ss:Type="String">snapshot save / restore / list</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">6</Data></Cell>
<Cell><Data ss:Type="String">Script runner</Data></Cell>
<Cell><Data ss:Type="String">Lets teams run project scripts with injected XRPL network context, so custom automation and workflows can share the same environment without manually wiring XRPL client connections, endpoints, and request setup first.</Data></Cell>
<Cell><Data ss:Type="String">run with injected XRPL_* environment</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">7</Data></Cell>
<Cell><Data ss:Type="String">Project bootstrap</Data></Cell>
<Cell><Data ss:Type="String">Scaffolds a starter project so users can begin with a working layout, scripts, and config instead of building the setup from scratch.</Data></Cell>
<Cell><Data ss:Type="String">init [directory]</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">8</Data></Cell>
<Cell><Data ss:Type="String">Useful examples</Data></Cell>
<Cell><Data ss:Type="String">Provides copy-pasteable example workflows so users can learn capabilities quickly and adapt them into their own scripts and tests.</Data></Cell>
<Cell><Data ss:Type="String">README examples and starter flows</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">9</Data></Cell>
<Cell><Data ss:Type="String">AMM wrapper</Data></Cell>
<Cell><Data ss:Type="String">Covers one of the core DeFi workflows expected in an XRPL developer tool.</Data></Cell>
<Cell><Data ss:Type="String">amm create / info</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">10</Data></Cell>
<Cell><Data ss:Type="String">NFT wrapper</Data></Cell>
<Cell><Data ss:Type="String">Provides end-to-end NFT demos and basic lifecycle operations for onboarding and testing.</Data></Cell>
<Cell><Data ss:Type="String">nft mint / list / offers / sell / accept / burn</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">11</Data></Cell>
<Cell><Data ss:Type="String">MPT wrapper</Data></Cell>
<Cell><Data ss:Type="String">Extends the CLI into newer XRPL token workflows and issuance operations.</Data></Cell>
<Cell><Data ss:Type="String">mpt create / destroy / authorize / set / info / pay / list</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">12</Data></Cell>
<Cell><Data ss:Type="String">DEX offers wrapper</Data></Cell>
<Cell><Data ss:Type="String">Supports basic trading and order-book interactions used in demos and local tests.</Data></Cell>
<Cell><Data ss:Type="String">offer create / cancel / list</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">13</Data></Cell>
<Cell><Data ss:Type="String">Trustline wrapper</Data></Cell>
<Cell><Data ss:Type="String">Essential for IOU workflows and issuer-account setup in local development.</Data></Cell>
<Cell><Data ss:Type="String">trustline set / freeze / list / issuer-defaults</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">14</Data></Cell>
<Cell><Data ss:Type="String">Escrow wrapper</Data></Cell>
<Cell><Data ss:Type="String">Covers common advanced transaction flows needed in educational and integration scenarios.</Data></Cell>
<Cell><Data ss:Type="String">escrow create / finish / cancel / list</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">15</Data></Cell>
<Cell><Data ss:Type="String">Checks wrapper</Data></Cell>
<Cell><Data ss:Type="String">Rounds out payment-related transaction helpers for demos and exploratory use.</Data></Cell>
<Cell><Data ss:Type="String">check create / cash / cancel / list</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">16</Data></Cell>
<Cell><Data ss:Type="String">Payment channels wrapper</Data></Cell>
<Cell><Data ss:Type="String">Adds streaming and off-ledger style payment primitives to the starter toolset.</Data></Cell>
<Cell><Data ss:Type="String">channel create / fund / claim / sign / verify / list</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">17</Data></Cell>
<Cell><Data ss:Type="String">AccountSet wrapper</Data></Cell>
<Cell><Data ss:Type="String">Needed for account flags, signer-list setup, and other account-configuration tasks.</Data></Cell>
<Cell><Data ss:Type="String">accountset set / clear / signer-list / info</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">18</Data></Cell>
<Cell><Data ss:Type="String">Tickets wrapper</Data></Cell>
<Cell><Data ss:Type="String">Supports newer transaction-submission patterns and sequence management flows.</Data></Cell>
<Cell><Data ss:Type="String">ticket create / list</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">19</Data></Cell>
<Cell><Data ss:Type="String">DepositPreauth wrapper</Data></Cell>
<Cell><Data ss:Type="String">Useful for account authorization workflows often needed in integration testing.</Data></Cell>
<Cell><Data ss:Type="String">depositpreauth authorize / unauthorize / list</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">20</Data></Cell>
<Cell><Data ss:Type="String">Clawback wrapper</Data></Cell>
<Cell><Data ss:Type="String">Covers modern token-control flows for both IOU and MPT assets.</Data></Cell>
<Cell><Data ss:Type="String">clawback IOU and MPT support</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">21</Data></Cell>
<Cell><Data ss:Type="String">Transaction history wrapper</Data></Cell>
<Cell><Data ss:Type="String">Gives users an immediate way to inspect account-level transaction history in the same CLI.</Data></Cell>
<Cell><Data ss:Type="String">tx list</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">22</Data></Cell>
<Cell><Data ss:Type="String">Multiple network targets</Data></Cell>
<Cell><Data ss:Type="String">Lets users run the same xrpl-up workflows against local, testnet, and devnet, which makes it easier to move from local development to shared testing environments without changing tools.</Data></Cell>
<Cell><Data ss:Type="String">local / testnet / devnet</Data></Cell>
</Row>
